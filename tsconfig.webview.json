{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"jsxImportSource": "preact",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": ["src/webview/**/*", "src/shared/**/*"]
}
