# nyc test coverage
.nyc_output

# Dependency directories
node_modules/
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# dotenv environment variables file
.env
.env.test
.direnv
result
result-*

# VS Code extension build output (yo code default)
out/
dist/
*.vsix

# Extension test host
.vscode-test/

# Optional REPL history
.node_repl_history

